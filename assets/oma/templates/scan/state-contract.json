{
  "schemaVersion": 1,
  "contractId": "akita-scan-state",
  "sharedStateBasePath": ".oma/state/shared/scan",
  "installedTemplateBasePath": ".oma/templates/scan",
  "requiredMachineState": [
    {
      "id": "scan-state",
      "path": ".oma/state/shared/scan/scan-state.json",
      "format": "json",
      "required": true,
      "requiredTopLevelFields": [
        "contracts",
        "targetCandidates",
        "priorArt",
        "serviceRuntimeProfile",
        "flowCandidates",
        "assertionOpportunities"
      ],
      "description": "Canonical persisted scan snapshot for the target repo. It must keep contracts, target candidates, prior art, runtime profile, flow candidates, and assertion opportunities in one durable JSON file."
    }
  ],
  "summaryState": {
    "path": ".oma/state/shared/scan/scan-summary.md",
    "templatePath": ".oma/templates/scan/scan-summary.md",
    "format": "markdown",
    "required": false,
    "canonical": false,
    "mustBeDerivedFrom": [
      "scan-state"
    ],
    "description": "Human-readable summary only. Canonical machine state stays in the single JSON file above."
  },
  "redaction": {
    "policyPath": ".oma/runtime/shared/data-handling-policy.json",
    "redactionRequired": true,
    "markdownIsSummaryOnly": true,
    "forbiddenSharedData": [
      "secrets",
      "tokens",
      "credentials",
      "raw auth headers",
      "machine-local values"
    ],
    "allowedSharedData": [
      "repo structure",
      "route hints",
      "prior-art paths",
      "capability evidence"
    ]
  }
}
